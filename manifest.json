{
  "manifest_version": 3,
  "name": "MongoLens",
  "version": "1.0.0",
  "author": "Dharaneesh R",
  "description": "Visualize MongoDB/Mongoose schemas as interactive ER diagrams. Upload your model files and instantly see your schema graph.",
  "browser_specific_settings": {
    "gecko": {
      "id": "mongolens@dharaneesh-r.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": [],
  "devtools_page": "devtools.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["panel.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
